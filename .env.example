# ─────────────────────────────────────────────
# BODRLESS API — Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# API Keys — Flight Suppliers
AMADEUS_API_KEY=your_amadeus_key
AMADEUS_API_SECRET=your_amadeus_secret
TRAVELDUQA_API_VERSION=v1
TRAVELDUQA_ACCESS_TOKEN=travelduqa_test_54499e97a61e8dc5b687540a0121df1b9101e2c1ee47202ebee09a6c0f7ad94c88f50aaa875f593f93dffdb479b18685a12606807706
FLUTTERWAVE_API_KEY=your_flutterwave_key

# API Keys — Bus/Ground Transport
BUUPASS_API_KEY=your_buupass_key
EASY_COACH_API_KEY=your_easycoach_key
IABIRI_API_KEY=4F5D3QC5-C94A-CFD5-87C1-4E2903311DF0
IABIRI_API_URL=http://bossapi.99synergy.com
IABIRI_POINTS_URL=https://api.iabiri.com
IABIRI_CURRENCY_ID=1

# API Keys — Hotels
BOOKING_COM_API_KEY=your_booking_key
EXPEDIA_API_KEY=your_expedia_key

# API Keys — Transfers
TRANSFERS_API_KEY=your_transfers_key

# WhatsApp Business
WHATSAPP_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_verify_token

# Redis (for caching and job queues)
REDIS_URL=redis://localhost:6379

# Database
DATABASE_URL=your_database_url

# Payments
MPESA_CONSUMER_KEY=your_mpesa_key
MPESA_CONSUMER_SECRET=your_mpesa_secret
MPESA_SHORTCODE=your_shortcode
MPESA_PASSKEY=your_passkey

# Internal
JWT_SECRET=your_jwt_secret
BODRLESS_WEBHOOK_SECRET=your_webhook_secret